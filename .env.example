# Firebase Web App Configuration (Project settings -> General -> Your apps -> Web app)
# Add the same keys in Vercel Project Settings -> Environment Variables
# Local dev: copy this file to .env and fill values.

# Public web API key (safe to expose in frontend, but still rotate if leaked).
VITE_FIREBASE_API_KEY=your_firebase_api_key

# Auth domain used by Firebase Auth. For stable hosted auth, keep firebaseapp.com domain,
# e.g. fitpulse-7173f.firebaseapp.com
# (your Vercel domain must still be added in Firebase Auth -> Settings -> Authorized domains).
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional for Analytics
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
